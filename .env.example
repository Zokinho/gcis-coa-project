# GCIS CoA Automation — Environment Variables
# Copy this to .env and fill in your values

# Anthropic API (required)
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# Database
DATABASE_URL=sqlite:///./gcis_coa.db

# Redis (for Celery task queue)
REDIS_URL=redis://localhost:6379/0

# Storage paths
STORAGE_PATH=./storage

# CORS origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000

# Server
HOST=0.0.0.0
PORT=8000

# SharePoint integration
MS_TENANT_ID=
MS_CLIENT_ID=
MS_CLIENT_SECRET=

# SharePoint default upload destination (for automated uploads from marketplace)
SP_DEFAULT_SITE_ID=
SP_DEFAULT_DRIVE_ID=
SP_DEFAULT_FOLDER_ID=

# Zoho CRM integration
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=
ZOHO_DATA_CENTER=CA

# IMAP email ingestion
IMAP_HOST=
IMAP_PORT=993
IMAP_USER=
IMAP_PASSWORD=
IMAP_USE_SSL=true
IMAP_POLL_INTERVAL_SECONDS=120
IMAP_FOLDER=INBOX
EMAIL_INGESTION_ENABLED=false
IMAP_USE_OAUTH2=false

# Email Security
EMAIL_SENDER_ALLOWLIST=
MAX_PDF_FILE_SIZE_MB=50
MAX_PDF_PAGE_COUNT=100
PDF_CONVERSION_TIMEOUT_SECONDS=120

# Evernote integration
EVERNOTE_DEVELOPER_TOKEN=
EVERNOTE_SANDBOX=false
EVERNOTE_IS_BUSINESS=true
EVERNOTE_NOTEBOOK_GUID=
